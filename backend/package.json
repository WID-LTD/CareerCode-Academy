{
  "name": "careercode-academy-backend",
  "version": "1.0.0",
  "description": "CareerCode Academy Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --require dotenv/config src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "tsx --require dotenv/config src/seed-courses.ts",
    "seed:admin": "tsx --require dotenv/config src/seed-admin.ts",
    "seed:exam": "tsx --require dotenv/config src/seed-exam-questions.ts",
    "generate-videos": "tsx --require dotenv/config src/generate-lesson-videos.ts",
    "migrate": "tsx --require dotenv/config src/migrate.ts",
    "migrate:s3": "tsx --require dotenv/config src/migrate-local-to-s3.ts",
    "migrate:videos": "tsx --require dotenv/config src/migrate-local-videos-to-s3.ts",
    "migrate:placeholders": "tsx --require dotenv/config src/link-unmatched-videos.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1070.0",
    "@google/generative-ai": "^0.21.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pdfkit": "^0.19.1",
    "pg": "^8.11.5",
    "socket.io": "^4.8.3",
    "streamifier": "^0.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.11.5",
    "eslint": "^9.0.0",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
